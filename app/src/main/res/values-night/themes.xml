<resources xmlns:tools="http://schemas.android.com/tools">

    <!-- Base Sky Blue Theme -->
    <style name="Base.Theme.PROJECTEXPO.SkyBlue" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Primary colors -->
        <item name="colorPrimary">@color/sky_blue</item>
        <item name="colorOnPrimary">@color/white</item>

        <!-- Secondary colors -->
        <item name="colorSecondary">@color/sky_on_primary</item>
        <item name="colorOnSecondary">@color/white</item>

        <!-- Background & text -->
        <item name="android:colorBackground">@color/bg_light</item>
        <item name="android:textColor">@color/black</item>
        <item name="android:textColorHint">@color/light_gray</item>

        <!-- Buttons -->
        <item name="materialButtonStyle">@style/Widget.ProjectExpo.Button</item>

        <!-- EditText / TextInputLayout -->
        <item name="textInputStyle">@style/Widget.ProjectExpo.EditText</item>
    </style>

    <!-- Button style -->
    <style name="Widget.ProjectExpo.Button" parent="Widget.Material3.Button">
        <item name="backgroundTint">@color/sky_blue</item>
        <item name="android:textColor">@color/white</item>
    </style>

    <!-- EditText style -->
    <style name="Widget.ProjectExpo.EditText" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxStrokeColor">@color/sky_blue</item>
        <item name="hintTextColor">@color/light_gray</item>
        <item name="android:textColor">@color/black</item>
    </style>

</resources>
