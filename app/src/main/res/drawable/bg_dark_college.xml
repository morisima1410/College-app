<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- College background image -->
    <item>
        <bitmap
            android:src="@drawable/slider1"
            android:gravity="fill" />
    </item>

    <!-- Sky Blue overlay for better readability -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#8047CFFF" /> <!-- semi-transparent sky blue (#80 transparency + #47CFFF) -->
        </shape>
    </item>

</layer-list>
