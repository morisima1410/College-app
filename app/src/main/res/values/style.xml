<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="CommonWhiteDatePicker" parent="Theme.MaterialComponents.Light.Dialog">

        <!-- Dialog background -->
        <item name="android:windowBackground">@color/white</item>

        <!-- Header -->
        <item name="colorPrimary">@color/white</item>
        <item name="colorOnPrimary">@color/black</item>

        <!-- Calendar text -->
        <item name="android:textColorPrimary">@color/black</item>
        <item name="android:textColorSecondary">@color/black</item>

        <!-- Selected date / accent (PURPLE) -->

        <!-- Spinner -->
        <item name="android:spinnerStyle">@style/CommonWhiteSpinner</item>
    </style>
    <style name="CircleImageView">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">50%</item>
    </style>


    <style name="CommonWhiteSpinner" parent="Widget.AppCompat.Spinner">

        <item name="android:background">@color/white</item>


    </style>
</resources>