<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".WelcomeActivity">

    <!-- MAIN CONTENT -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- TOOLBAR -->
        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="@color/sky_blue"
            android:title="C.U.Shah polytechnic"
            android:titleTextColor="@color/white"
            app:navigationIcon="@drawable/ic_menu" />

        <!-- SCROLL CONTENT -->
        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center_horizontal">

                <!-- LOGO -->
                <ImageView
                    android:layout_width="200dp"
                    android:layout_height="200dp"
                    android:layout_marginTop="16dp"
                    android:src="@drawable/logo" />

                <!-- TITLE -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:padding="16dp"
                    android:background="@drawable/edittext_bg">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="About C.U. Shah Government Polytechnic, Wadhwan City"
                        android:textAlignment="center"
                        android:textStyle="bold"
                        android:textSize="18sp"
                        android:textColor="@color/black" />
                </LinearLayout>

                <!-- ABOUT WEBVIEW -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:padding="10dp"
                    android:background="@drawable/edittext_bg"
                    tools:ignore="WebViewLayout">

                    <WebView
                        android:id="@+id/aboutWebView"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content" />
                </LinearLayout>

                <!-- VISION -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:padding="16dp"
                    android:orientation="vertical"
                    android:background="@drawable/edittext_bg">

                    <TextView
                        android:layout_height="match_parent"
                        android:layout_width="wrap_content"
                        android:text="Institute Vision"
                        android:textStyle="bold"
                        android:textSize="20sp"
                        android:layout_gravity="center"
                        android:textColor="@color/black" />

                    <TextView
                        android:layout_height="match_parent"
                        android:layout_width="wrap_content"
                        android:text="Produce competent diploma engineers for the society."
                        android:layout_marginTop="8dp"
                        android:textSize="16sp"
                        android:gravity="center" />
                </LinearLayout>

                <!-- MISSION -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:padding="16dp"
                    android:orientation="vertical"
                    android:background="@drawable/edittext_bg">

                    <TextView
                        android:layout_height="match_parent"
                        android:layout_width="wrap_content"
                        android:text="Institute Mission"
                        android:textStyle="bold"
                        android:textSize="20sp"
                        android:layout_gravity="center" />

                    <TextView
                        android:layout_height="match_parent"
                        android:layout_width="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="1. Impart technical knowledge and skills.\n\n2. Inculcate professional values.\n\n3. Promote entrepreneurship."
                        android:textSize="16sp" />
                </LinearLayout>

                <!-- IMAGE SECTION -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:padding="16dp"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/edittext_bg"
                    tools:ignore="WebViewLayout">

                    <ImageView
                        android:layout_width="200dp"
                        android:layout_height="200dp"
                        android:src="@drawable/cd1" />

                    <TextView
                        android:layout_height="match_parent"
                        android:layout_width="wrap_content"
                        android:text="Section Title"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="@color/sky_blue"
                        android:layout_marginTop="8dp" />

                    <WebView
                        android:id="@+id/sectionDescriptionWeb"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content" />
                </LinearLayout>

                <!-- FOOTER -->
                <TextView
                    android:layout_height="match_parent"
                    android:layout_width="wrap_content"
                    android:layout_margin="16dp"
                    android:text="© 2025 C. U. Shah Polytechnic\nMade with ❤ in India"
                    android:textSize="12sp"
                    android:gravity="center" />
            </LinearLayout>
        </ScrollView>
    </LinearLayout>

    <!-- NAVIGATION DRAWER -->
    <com.google.android.material.navigation.NavigationView
        android:id="@+id/navigationView"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        app:headerLayout="@layout/sidebar_header"
        app:menu="@menu/welcome_menu" />

</androidx.drawerlayout.widget.DrawerLayout>
